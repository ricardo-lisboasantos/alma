flowchart TD
    subgraph API["API Layer"]
        A1[alma_multiply] --> A2[alma_multiply_full]
        A2 --> A3[alma_multiply_auto]
    end

    subgraph Classify["Classification Layer"]
        C1[classify_block] --> C2[SVD Computation<br/>dgesvd]
        C2 --> C3[Rank Determination<br/>Threshold 0.1]
        C3 --> C4[Cost-Benefit<br/>Savings Check]
        C4 --> C5{LowRank?}
        C5 -->|Yes| C6[Store U, S, VT]
        C5 -->|No| C7[Mark Dense]
    end

    subgraph Execute["Execution Layer"]
        E1[Dispatch] --> E2{LowRank × LowRank?}
        E2 -->|Yes| E3[multiply_lowrank_block]
        E2 -->|No| E4[multiply_dense_block<br/>BLAS dgemm]
    end

    A1 --> Classify
    Classify --> Execute
