sequenceDiagram
    participant Main
    participant Alma
    participant BLAS
    participant OpenMP

    Main->>Alma: alma_multiply(A, B, C, n, blockSize)

    alt n <= 256
        Alma->>BLAS: cblas_dgemm
        BLAS-->>Alma: result
    else n > 256
        Alma->>Alma: classify_all_blocks(A)
        Alma->>Alma: classify_all_blocks(B)
        Alma->>OpenMP: parallel for initialization
        OpenMP-->>Alma: C initialized
        Alma->>OpenMP: parallel for block multiply
        loop For each block
            OpenMP->>BLAS: cblas_dgemm(block)
            BLAS-->>OpenMP: partial result
        end
        OpenMP-->>Alma: C complete
    end

    Alma-->>Main: done
